# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from https://app.supabase.com → Project → Settings → API
SUPABASE_URL=
SUPABASE_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Your personal Telegram chat ID (send /start to @userinfobot to find it)
ADMIN_CHAT_ID=

# ── UPI Payments ──────────────────────────────────────────────────────────────
# Your UPI ID (e.g. yourname@upi or phone@paytm)
UPI_ID=

# ── Render Deployment ─────────────────────────────────────────────────────────
# The service name from Render dashboard (e.g. priyabot → priyabot.onrender.com)
RENDER_APP_NAME=

# ── Optional ──────────────────────────────────────────────────────────────────
# Random secret string to verify Telegram webhook requests
WEBHOOK_SECRET=
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
